# Copy this file to .env and fill in your values
# Get these from your Supabase project settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Your admin email address — this account gets admin role automatically
VITE_ADMIN_EMAIL=your@email.com

# Calendly booking URL — paste your event URL here to enable the floating "Schedule Service" button
# Example: https://calendly.com/your-username/heating-service
VITE_CALENDLY_URL=
